PORT=5000
MONGODB_URI=your_mongodb_connection_string_here
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=1d
FRONTEND_URL=http://localhost:5173
# Your Google Gemini / Generative AI API key
GEMINI_API_KEY=YOUR_API_KEY_HERE

# Optional: set this to a supported model name if discovery fails
# Example: GENAI_MODEL=models/chat-bison-001
GENAI_MODEL=

# Note: Do NOT commit real secrets to git. Use .env locally and set
# production env vars securely in your deployment environment.
